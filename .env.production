# World Monitor — Production Environment (local laptop server)
# VITE_WS_API_URL is intentionally empty so API calls are served locally.

VITE_VARIANT=full
VITE_MAP_INTERACTION_MODE=3d

# Leave empty to serve API from this machine (not the hosted backend)
VITE_WS_API_URL=

# Optional keys — add to unlock specific data sources (see .env.example)
# WS_RELAY_URL=
# VITE_WS_RELAY_URL=
# WTO_API_KEY=
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
